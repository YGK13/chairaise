# ChaiRaise — Required Environment Variables
# Copy to .env.local and fill in your values

# Database (Neon Postgres) — REQUIRED
# Install: vercel integration add neon
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# AI API Keys (at least one required for AI features)
ANTHROPIC_API_KEY=sk-ant-...
PERPLEXITY_API_KEY=pplx-...

# Email Sending (Resend) — required for real email delivery
# Install: vercel integration add resend
RESEND_API_KEY=re_...
EMAIL_FROM=hello@yourdomain.com

# NextAuth.js — REQUIRED
# Generate: openssl rand -base64 32
AUTH_SECRET=your-secret-here
NEXTAUTH_URL=http://localhost:3004

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# LinkedIn OAuth (optional)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Schema setup protection
SETUP_SECRET=your-setup-secret
