# ChaiRaise — Required Environment Variables
# Copy to .env.local and fill in your values

# Database (Neon Postgres) — REQUIRED
# Install: vercel integration add neon
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# AI API Keys (at least one required for AI features)
ANTHROPIC_API_KEY=sk-ant-...
PERPLEXITY_API_KEY=pplx-...

# Email Sending (Resend) — required for real email delivery
# Install: vercel integration add resend
RESEND_API_KEY=re_...
EMAIL_FROM=hello@yourdomain.com

# NextAuth.js — REQUIRED
# Generate: openssl rand -base64 32
AUTH_SECRET=your-secret-here
NEXTAUTH_URL=http://localhost:3004

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# LinkedIn OAuth (optional)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Schema setup protection
SETUP_SECRET=your-setup-secret

# ============================================================
# Stripe — REQUIRED for billing (see /api/billing/*)
# ============================================================
# Dashboard: https://dashboard.stripe.com/apikeys (live for prod)
STRIPE_SECRET_KEY=sk_live_or_sk_test_xxx
# Dashboard -> Developers -> Webhooks -> your endpoint -> Signing secret.
# The webhook now HARD-FAILS if this is not set (no more silent
# accept-anything dev fallback). See app/api/billing/webhook/route.js.
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Dashboard -> Products -> Pro plan -> Price ID (price_...)
STRIPE_PRO_PRICE_ID=price_xxx
# Optional: Stripe Connect account routing (shared account setup only)
STRIPE_ACCOUNT_ID=

# ============================================================
# Zapier / partner webhook -> POST /api/webhook
# ============================================================
# Hard-fail if missing. Generate with: openssl rand -hex 32
WEBHOOK_SECRET=

# ============================================================
# Contact form + owner-only endpoints
# ============================================================
# Address the /api/contact route emails when someone submits the form.
CONTACT_EMAIL=yuri.kruman@gmail.com
# Comma-separated allowlist mirrored in lib/plan.js isOwnerEmail().
# Kept here for ops visibility; the source of truth is the constant in
# lib/plan.js so redeploying without this var does not silently unlock.
OWNER_EMAILS=yuri.kruman@gmail.com

# ============================================================
# Rate limiting (Upstash Redis, optional)
# ============================================================
# If unset, rate limiters fall back to a per-instance in-memory bucket
# (fine for MVP, imperfect across cold starts). Vercel Upstash integration
# provisions these automatically.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
